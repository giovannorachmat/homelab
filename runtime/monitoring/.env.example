# Service-specific schema configurations
MONITORING_DB_SCHEMA=your-monitoring-db-schema-here

# ######################
# MONITORING CONFIGURATION
# ######################

# Container names
NODE_EXPORTER_CONTAINER=your-node-exporter-container-here
PROMETHEUS_CONTAINER=your-prometheus-container-here
GRAFANA_CONTAINER=your-grafana-container-here
LOKI_CONTAINER=your-loki-container-here
PROMTAIL_CONTAINER=your-promtail-container-here

# Monitoring ports
NODE_EXPORTER_PORT=your-node-exporter-port-here
PROMETHEUS_PORT=your-prometheus-port-here
GRAFANA_PORT=your-grafana-port-here
LOKI_PORT=your-loki-port-here
PROMTAIL_PORT=your-promtail-port-here

# Grafana configuration
GF_PATHS_PROVISIONING=your-gf-paths-provisioning-here
GF_AUTH_ANONYMOUS_ENABLED=your-gf-auth-anonymous-enabled-here
GF_AUTH_ANONYMOUS_ORG_ROLE=your-gf-auth-anonymous-org-role-here
GF_FEATURE_TOGGLES_ENABLE=your-gf-feature-toggles-enable-here

# ######################
# RESOURCE LIMITS
# ######################

# Monitoring resource limits
PROMETHEUS_CPUS=your-prometheus-cpus-here
PROMETHEUS_MEMORY=your-prometheus-memory-here
GRAFANA_CPUS=your-grafana-cpus-here
GRAFANA_MEMORY=your-grafana-memory-here
LOKI_CPUS=your-loki-cpus-here
LOKI_MEMORY=your-loki-memory-here
PROMTAIL_CPUS=your-promtail-cpus-here
PROMTAIL_MEMORY=your-promtail-memory-here
NODE_EXPORTER_CPUS=your-node-exporter-cpus-here
NODE_EXPORTER_MEMORY=your-node-exporter-memory-here

# ######################
# HEALTH CHECK CONFIGURATION
# ######################

# Health check intervals (in seconds)
HEALTH_CHECK_INTERVAL=your-health-check-interval-here
HEALTH_CHECK_TIMEOUT=your-health-check-timeout-here
HEALTH_CHECK_RETRIES=your-health-check-retries-here
HEALTH_CHECK_START_PERIOD=your-health-check-start-period-here

# ######################
# LOGGING CONFIGURATION
# ######################

# Log levels
LOG_LEVEL=your-log-level-here
DEBUG_LOG_LEVEL=your-debug-log-level-here

# Log retention
LOG_RETENTION_DAYS=your-log-retention-days-here
LOG_RETENTION_SIZE=your-log-retention-size-here
